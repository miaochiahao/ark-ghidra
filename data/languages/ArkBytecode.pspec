<?xml version="1.0" encoding="UTF-8"?>
<processor_spec>
  <properties>
    <property key="DisableAllAnalyzers" value="true"/>
    <property key="Analyzers.Ark Bytecode Method Markup" value="true"/>
  </properties>
  <inferptrbounds>
    <range space="ram" first="0" last="0"/>
  </inferptrbounds>
</processor_spec>
