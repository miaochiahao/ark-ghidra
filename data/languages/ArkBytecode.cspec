<?xml version="1.0" encoding="UTF-8"?>
<compiler_spec>
  <data_organization>
    <absolute_max_alignment value="0"/>
    <machine_alignment value="1"/>
    <default_alignment value="1"/>
    <default_pointer_alignment value="4"/>
    <pointer_size value="4"/>
    <char_type signed="false"/>
    <char_size value="1"/>
    <short_size value="2"/>
    <integer_size value="4"/>
    <long_size value="4"/>
    <long_long_size value="8"/>
    <float_size value="4"/>
    <double_size value="8"/>
    <long_double_size value="8"/>
    <size_alignment_map>
      <entry size="1" alignment="1"/>
      <entry size="2" alignment="1"/>
      <entry size="4" alignment="1"/>
      <entry size="8" alignment="1"/>
    </size_alignment_map>
  </data_organization>

  <global>
    <range space="ram"/>
  </global>

  <stackpointer register="sp" space="ram" growth="negative"/>

  <default_proto>
    <prototype name="__arkcall" extrapop="0" stackshift="0">
      <input>
        <pentry minsize="1" maxsize="4" align="4">
          <register name="v0"/>
        </pentry>
        <pentry minsize="1" maxsize="4" align="4">
          <register name="v1"/>
        </pentry>
        <pentry minsize="1" maxsize="4" align="4">
          <register name="v2"/>
        </pentry>
        <pentry minsize="1" maxsize="4" align="4">
          <register name="v3"/>
        </pentry>
      </input>
      <output>
        <pentry maxsize="4" minsize="1">
          <register name="acc"/>
        </pentry>
      </output>
      <unaffected>
        <register name="fp"/>
        <register name="sp"/>
      </unaffected>
    </prototype>
  </default_proto>
</compiler_spec>
