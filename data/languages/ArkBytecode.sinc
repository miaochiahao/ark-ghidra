# ===========================================================
# Instruction Definitions
# ===========================================================

# --- Constant loaders (op_none format) ---

:ldundefined    is opcode=0x00 { acc = 0; }
:ldnull         is opcode=0x01 { acc = 0; }
:ldtrue         is opcode=0x02 { acc = 1; }
:ldfalse        is opcode=0x03 { acc = 0; }
:createemptyobject is opcode=0x04 { acc = arkNewObject(); }

# --- Array/Object creation (op_imm_8) ---

:createemptyarray i8_1   is opcode=0x05; i8_1 { acc = arkCreateArray(i8_1); }
:getpropiterator  is opcode=0x66 { acc = arkGetPropIterator(); }
:poplexenv        is opcode=0x69 { }
:ldnan            is opcode=0x6A { acc = 0x7FF8000000000000; }
:ldinfinity       is opcode=0x6B { acc = 0x7FF0000000000000; }
:getunmappedargs  is opcode=0x6C { acc = arkCallRuntime(); }
:ldglobal         is opcode=0x6D { acc = arkLoadProperty(); }
:ldnewtarget      is opcode=0x6E { acc = arkLoadProperty(); }
:ldthis           is opcode=0x6F { acc = arkLoadProperty(); }
:ldhole           is opcode=0x70 { acc = 0; }
:ldsymbol         is opcode=0xAD { acc = arkCallRuntime(); }
:asyncfunctionenter is opcode=0xAE { acc = arkCallRuntime(); }
:ldfunction       is opcode=0xAF { acc = arkLoadProperty(); }
:debugger         is opcode=0xB0 { arkDebugger(); }
:return           is opcode=0x64 { return [sp]; }
:returnundefined  is opcode=0x65 { acc = 0; return [sp]; }
:nop              is opcode=0xD5 { }
:resumegenerator  is opcode=0xBF { }
:getresumemode    is opcode=0xC0 { }
:istrue           is opcode=0x23 { acc = zext(acc != 0); }
:isfalse          is opcode=0x24 { acc = zext(acc == 0); }
:dynamicimport    is opcode=0xBD { acc = arkDynamicImport(); }

# --- Object creation with register args ---

:creategeneratorobj vr1       is opcode=0xB1; vr1 { acc = arkNewObject(); }
:createiterresultobj vr1, vr2 is opcode=0xB2; vr1; vr2 { acc = arkNewObject(); }
:createasyncgeneratorobj vr1  is opcode=0xB7; vr1 { acc = arkNewObject(); }

# --- Binary operations (op_imm_8_v_8) ---

:add2 i8_1, vr1    is opcode=0x0A; i8_1; vr1 { acc = acc + vr1; }
:sub2 i8_1, vr1    is opcode=0x0B; i8_1; vr1 { acc = acc - vr1; }
:mul2 i8_1, vr1    is opcode=0x0C; i8_1; vr1 { acc = acc * vr1; }
:div2 i8_1, vr1    is opcode=0x0D; i8_1; vr1 { acc = acc / vr1; }
:mod2 i8_1, vr1    is opcode=0x0E; i8_1; vr1 { acc = acc % vr1; }
:eq i8_1, vr1      is opcode=0x0F; i8_1; vr1 { acc = zext(acc == vr1); }
:noteq i8_1, vr1   is opcode=0x10; i8_1; vr1 { acc = zext(acc != vr1); }
:less i8_1, vr1    is opcode=0x11; i8_1; vr1 { acc = zext(acc s< vr1); }
:lesseq i8_1, vr1  is opcode=0x12; i8_1; vr1 { acc = zext(acc s<= vr1); }
:greater i8_1, vr1 is opcode=0x13; i8_1; vr1 { acc = zext(vr1 s< acc); }
:greatereq i8_1, vr1 is opcode=0x14; i8_1; vr1 { acc = zext(vr1 s<= acc); }
:shl2 i8_1, vr1    is opcode=0x15; i8_1; vr1 { acc = acc << vr1; }
:shr2 i8_1, vr1    is opcode=0x16; i8_1; vr1 { acc = acc >> vr1; }
:ashr2 i8_1, vr1   is opcode=0x17; i8_1; vr1 { acc = acc s>> vr1; }
:and2 i8_1, vr1    is opcode=0x18; i8_1; vr1 { acc = acc & vr1; }
:or2 i8_1, vr1     is opcode=0x19; i8_1; vr1 { acc = acc | vr1; }
:xor2 i8_1, vr1    is opcode=0x1A; i8_1; vr1 { acc = acc ^ vr1; }
:exp i8_1, vr1     is opcode=0x1B; i8_1; vr1 { acc = arkCallRuntime(); }

# --- Comparison with register --
:isin i8_1, vr1       is opcode=0x25; i8_1; vr1 { acc = arkCallRuntime(); }
:instanceof i8_1, vr1 is opcode=0x26; i8_1; vr1 { acc = arkInstanceOf(); }
:strictnoteq i8_1, vr1 is opcode=0x27; i8_1; vr1 { acc = zext(acc != vr1); }
:stricteq i8_1, vr1   is opcode=0x28; i8_1; vr1 { acc = zext(acc == vr1); }

# --- Unary operations (op_imm_8) ---

:typeof i8_1    is opcode=0x1C; i8_1 { acc = arkTypeOf(); }
:tonumber i8_1  is opcode=0x1D; i8_1 { }
:tonumeric i8_1 is opcode=0x1E; i8_1 { }
:neg i8_1       is opcode=0x1F; i8_1 { acc = -acc; }
:not i8_1       is opcode=0x20; i8_1 { acc = ~acc; }
:inc i8_1       is opcode=0x21; i8_1 { acc = acc + 1; }
:dec i8_1       is opcode=0x22; i8_1 { acc = acc - 1; }

# --- Call instructions ---

:callarg0 i8_1           is opcode=0x29; i8_1 { acc = arkCallArg(); }
:callarg1 i8_1, vr1      is opcode=0x2A; i8_1; vr1 { acc = arkCallArg(); }
:callargs2 i8_1, vr1, vr2  is opcode=0x2B; i8_1; vr1; vr2 { acc = arkCallArg(); }
:callargs3 i8_1, vr1, vr2, vr3 is opcode=0x2C; i8_1; vr1; vr2; vr3 { acc = arkCallArg(); }

:callthis0 i8_1, vr1            is opcode=0x2D; i8_1; vr1 { acc = arkCallArg(); }
:callthis1 i8_1, vr1, vr2       is opcode=0x2E; i8_1; vr1; vr2 { acc = arkCallArg(); }
:callthis2 i8_1, vr1, vr2, vr3  is opcode=0x2F; i8_1; vr1; vr2; vr3 { acc = arkCallArg(); }
:callthis3 i8_1, vr1, vr2, vr3, vr4 is opcode=0x30; i8_1; vr1; vr2; vr3; vr4 { acc = arkCallArg(); }

# --- Register moves (4-bit packed register pair) ---

:mov vr_lo, vr_hi is opcode=0x44; vr_lo & vr_hi { vr_lo = vr_hi; }
:lda vr1       is opcode=0x60; vr1 { acc = vr1; }
:sta vr1       is opcode=0x61; vr1 { vr1 = acc; }

# --- Load immediate ---

:ldai i32s   is opcode=0x62; i32s { acc = i32s; }
:fldai i64s  is opcode=0x63; i64s { acc64 = i64s; }

# --- Lexical variable access (4-bit packed) ---

:ldlexvar lex_lvl, lex_slt is opcode=0x3C; lex_lvl & lex_slt { acc = arkLoadProperty(); }
:stlexvar lex_lvl, lex_slt is opcode=0x3D; lex_lvl & lex_slt { arkStoreProperty(); }

# --- String constant load ---

:lda.str i16_1 is opcode=0x3E; i16_1 { acc = zext(i16_1); }

# --- Property access by name (op_imm_8_id_16) ---

:tryldglobalbyname i8_1, i16_2     is opcode=0x3F; i8_1; i16_2 { acc = arkLoadProperty(); }
:trystglobalbyname i8_1, i16_2     is opcode=0x40; i8_1; i16_2 { arkStoreProperty(); }
:ldobjbyname i8_1, i16_2           is opcode=0x42; i8_1; i16_2 { acc = arkLoadProperty(); }
:stobjbyname i8_1, i16_2, vr1      is opcode=0x43; i8_1; i16_2; vr1 { arkStoreProperty(); }
:ldsuperbyname i8_1, i16_2         is opcode=0x46; i8_1; i16_2 { acc = arkLoadProperty(); }
:ldthisbyname i8_1, i16_2          is opcode=0x49; i8_1; i16_2 { acc = arkLoadProperty(); }
:stthisbyname i8_1, i16_2, vr1     is opcode=0x4A; i8_1; i16_2; vr1 { arkStoreProperty(); }
:stownbyname i8_1, i16_2, vr1      is opcode=0x7A; i8_1; i16_2; vr1 { arkStoreProperty(); }
:stsuperbyname i8_1, i16_2, vr1    is opcode=0xD0; i8_1; i16_2; vr1 { arkStoreProperty(); }

# --- Property access by value (op_imm_8_v_8) ---

:ldobjbyvalue i8_1, vr1       is opcode=0x37; i8_1; vr1 { acc = arkLoadProperty(); }
:stobjbyvalue i8_1, vr1, vr2  is opcode=0x38; i8_1; vr1; vr2 { arkStoreProperty(); }
:ldsuperbyvalue i8_1, vr1     is opcode=0x39; i8_1; vr1 { acc = arkLoadProperty(); }
:ldthisbyvalue i8_1           is opcode=0x4B; i8_1 { acc = arkLoadProperty(); }
:stthisbyvalue i8_1, vr1      is opcode=0x4C; i8_1; vr1 { arkStoreProperty(); }
:stownbyvalue i8_1, vr1, vr2  is opcode=0x78; i8_1; vr1; vr2 { arkStoreProperty(); }
:stsuperbyvalue i8_1, vr1, vr2 is opcode=0xC9; i8_1; vr1; vr2 { arkStoreProperty(); }

# --- Property access by index (op_imm_8_imm_16) ---

:ldobjbyindex i8_1, i16_2         is opcode=0x3A; i8_1; i16_2 { acc = arkLoadProperty(); }
:stobjbyindex i8_1, vr1, i16_2    is opcode=0x3B; i8_1; vr1; i16_2 { arkStoreProperty(); }
:stownbyindex i8_1, vr1, i16_2    is opcode=0x79; i8_1; vr1; i16_2 { arkStoreProperty(); }

# --- Global variable access ---

:ldglobalvar i8_1, i16_2        is opcode=0x41; i8_1; i16_2 { acc = arkLoadProperty(); }
:stglobalvar i8_1, i16_2        is opcode=0x7F; i8_1; i16_2 { arkStoreProperty(); }
:stconsttoglobalrecord i8_1, i16_2 is opcode=0x47; i8_1; i16_2 { arkStoreProperty(); }
:sttoglobalrecord i8_1, i16_2   is opcode=0x48; i8_1; i16_2 { arkStoreProperty(); }

# --- Module variable access ---

:getmodulenamespace i8_1  is opcode=0x7B; i8_1 { acc = arkLoadProperty(); }
:stmodulevar i8_1         is opcode=0x7C; i8_1 { arkStoreProperty(); }
:ldlocalmodulevar i8_1    is opcode=0x7D; i8_1 { acc = arkLoadProperty(); }
:ldexternalmodulevar i8_1 is opcode=0x7E; i8_1 { acc = arkLoadProperty(); }

# --- Jump instructions (8-bit offset) ---

:jmp jmp8       is opcode=0x4D; jmp8 { goto jmp8; }
:jeqz jmp8      is opcode=0x4F; jmp8 { if (acc == 0) goto jmp8; }
:jnez jmp8      is opcode=0x51; jmp8 { if (acc != 0) goto jmp8; }
:jstricteqz jmp8    is opcode=0x52; jmp8 { if (acc == 0) goto jmp8; }
:jnstricteqz jmp8   is opcode=0x53; jmp8 { if (acc != 0) goto jmp8; }
:jeqnull jmp8       is opcode=0x54; jmp8 { if (acc == 0) goto jmp8; }
:jnenull jmp8       is opcode=0x55; jmp8 { if (acc != 0) goto jmp8; }
:jstricteqnull jmp8 is opcode=0x56; jmp8 { if (acc == 0) goto jmp8; }
:jnstricteqnull jmp8 is opcode=0x57; jmp8 { if (acc != 0) goto jmp8; }
:jequndefined jmp8   is opcode=0x58; jmp8 { if (acc == 0) goto jmp8; }
:jneundefined jmp8   is opcode=0x59; jmp8 { if (acc != 0) goto jmp8; }

# Jump with register comparison (8-bit offset)
:jeq vr1, jmp8    is opcode=0x5C; vr1; jmp8 { if (acc == vr1) goto jmp8; }
:jne vr1, jmp8    is opcode=0x5D; vr1; jmp8 { if (acc != vr1) goto jmp8; }
:jstricteq vr1, jmp8   is opcode=0x5E; vr1; jmp8 { if (acc == vr1) goto jmp8; }
:jnstricteq vr1, jmp8  is opcode=0x5F; vr1; jmp8 { if (acc != vr1) goto jmp8; }

# --- Iterator ---

:getiterator i8_1       is opcode=0x67; i8_1 { acc = arkGetIterator(); }
:closeiterator i8_1, vr1 is opcode=0x68; i8_1; vr1 { arkCloseIterator(); }
:getnextpropname vr1    is opcode=0x36; vr1 { acc = arkLoadProperty(); }

# --- Function definition ---

:definefunc i8_1, i16_2, i8_3 is opcode=0x33; i8_1; i16_2; i8_3 { acc = arkDefineFunc(); }
:definemethod i8_1, i16_2, i8_3 is opcode=0x34; i8_1; i16_2; i8_3 { acc = arkDefineFunc(); }

# --- Object with nameset ---

:stownbyvaluewithnameset i8_1, vr1, vr2 is opcode=0x99; i8_1; vr1; vr2 { arkStoreProperty(); }
:stownbynamewithnameset i8_1, i16_2, vr1 is opcode=0x8E; i8_1; i16_2; vr1 { arkStoreProperty(); }

# --- Set object with proto ---

:setobjectwithproto i8_1, vr1 is opcode=0x77; i8_1; vr1 { arkStoreProperty(); }

# --- Misc ---

:gettemplateobject i8_1 is opcode=0x76; i8_1 { acc = arkCallRuntime(); }
:delobjprop vr1          is opcode=0xC2; vr1 { acc = arkCallRuntime(); }
:suspendgenerator vr1    is opcode=0xC3; vr1 { arkCallRuntime(); }
:asyncfunctionawaituncaught vr1 is opcode=0xC4; vr1 { arkCallRuntime(); }
:copydataproperties vr1  is opcode=0xC5; vr1 { arkCallRuntime(); }
:starrayspread vr1, vr2  is opcode=0xC6; vr1; vr2 { arkStoreProperty(); }
:asyncfunctionresolve vr1 is opcode=0xCD; vr1 { arkCallRuntime(); }
:asyncfunctionreject vr1  is opcode=0xCE; vr1 { arkCallRuntime(); }
:copyrestargs i8_1        is opcode=0xCF; i8_1 { acc = arkCallRuntime(); }
:ldbigint i16_1           is opcode=0xD3; i16_1 { acc = zext(i16_1); }
:setgeneratorstate i8_1   is opcode=0xD6; i8_1 { }
:getasynciterator i8_1    is opcode=0xD7; i8_1 { acc = arkGetIterator(); }

# --- Newobj range ---

:newobjrange i8_1, i8_2, vr1 is opcode=0x08; i8_1; i8_2; vr1 { acc = arkNewObject(); }
:newlexenv i8_1             is opcode=0x09; i8_1 { acc = arkNewObject(); }
:supercallthisrange i8_1, i8_2, vr1 is opcode=0x32; i8_1; i8_2; vr1 { acc = arkCallArg(); }
:callrange i8_1, i8_2, vr1 is opcode=0x73; i8_1; i8_2; vr1 { acc = arkCallArg(); }
:supercallarrowrange i8_1, i8_2, vr1 is opcode=0xBB; i8_1; i8_2; vr1 { acc = arkCallArg(); }

# --- Call this range ---

:callthisrange i8_1, i8_2, vr1 is opcode=0x31; i8_1; i8_2; vr1 { acc = arkCallArg(); }

# --- Special operations ---

:supercallspread i8_1, vr1   is opcode=0xB9; i8_1; vr1 { acc = arkCallArg(); }
:apply i8_1, vr1, vr2        is opcode=0xBA; i8_1; vr1; vr2 { acc = arkCallArg(); }
:newobjapply i8_1, vr1        is opcode=0xB4; i8_1; vr1 { acc = arkNewObject(); }

# --- Create with buffer ---

:createarraywithbuffer i8_1, i16_2     is opcode=0x06; i8_1; i16_2 { acc = arkCreateArray(); }
:createobjectwithbuffer i8_1, i16_2    is opcode=0x07; i8_1; i16_2 { acc = arkCreateObject(); }
:createregexpwithliteral i8_1, i16_2, i8_3 is opcode=0x71; i8_1; i16_2; i8_3 { acc = arkNewObject(); }

# --- Async generator ---

:asyncgeneratorresolve vr1, vr2, vr3 is opcode=0xB8; vr1; vr2; vr3 { acc = arkCallRuntime(); }
:asyncgeneratorreject vr1           is opcode=0x97; vr1 { arkCallRuntime(); }

# --- Private property ---

:ldprivateproperty i8_1, i16_2, i16_3 is opcode=0xD8; i8_1; i16_2; i16_3 { acc = arkLoadProperty(); }
:stprivateproperty i8_1, i16_2, i16_3, vr1 is opcode=0xD9; i8_1; i16_2; i16_3; vr1 { arkStoreProperty(); }
:testin i8_1, i16_2, i16_3 is opcode=0xDA; i8_1; i16_2; i16_3 { acc = arkCallRuntime(); }
:definefieldbyname i8_1, i16_2, vr1 is opcode=0xDB; i8_1; i16_2; vr1 { arkStoreProperty(); }
:definepropertybyname i8_1, i16_2, vr1 is opcode=0xDC; i8_1; i16_2; vr1 { arkStoreProperty(); }

# --- Class definition ---

:defineclasswithbuffer i8_1, i16_2, i16_3, i8_3, vr1 is opcode=0x35; i8_1; i16_2; i16_3; i8_3; vr1 { acc = arkDefineFunc(); }

# --- Define getter/setter ---

:definegettersetterbyvalue vr1, vr2, vr3, vr4 is opcode=0xBC; vr1; vr2; vr3; vr4 { arkStoreProperty(); }

# --- Create with excluded keys ---

:createobjectwithexcludedkeys i8_1, vr1, vr2 is opcode=0xB3; i8_1; vr1; vr2 { acc = arkNewObject(); }

# --- Lex env with name ---

:newlexenvwithname i8_1, i16_2 is opcode=0xB6; i8_1; i16_2 { acc = arkNewObject(); }

# ===========================================================
# Wide prefix (0xFD) instructions
# ===========================================================

:createemptyarray i16_1 is wide_prefix=0xFD & wide_opcode=0x80; i16_1 { acc = arkCreateArray(); }
:createarraywithbuffer i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x81; i16_1; i16_2 { acc = arkCreateArray(); }
:createobjectwithbuffer i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x82; i16_1; i16_2 { acc = arkCreateObject(); }
:newobjrange i16_1, i8_1, vr1 is wide_prefix=0xFD & wide_opcode=0x83; i16_1; i8_1; vr1 { acc = arkNewObject(); }
:typeof i16_1 is wide_prefix=0xFD & wide_opcode=0x84; i16_1 { acc = arkTypeOf(); }
:ldobjbyvalue i16_1, vr1 is wide_prefix=0xFD & wide_opcode=0x85; i16_1; vr1 { acc = arkLoadProperty(); }
:stobjbyvalue i16_1, vr1, vr2 is wide_prefix=0xFD & wide_opcode=0x86; i16_1; vr1; vr2 { arkStoreProperty(); }
:ldsuperbyvalue i16_1, vr1 is wide_prefix=0xFD & wide_opcode=0x87; i16_1; vr1 { acc = arkLoadProperty(); }
:ldobjbyindex i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x88; i16_1; i16_2 { acc = arkLoadProperty(); }
:stobjbyindex i16_1, vr1, i16_2 is wide_prefix=0xFD & wide_opcode=0x89; i16_1; vr1; i16_2 { arkStoreProperty(); }
:ldlexvar i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x8A; i16_1; i16_2 { acc = arkLoadProperty(); }
:stlexvar i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x8B; i16_1; i16_2 { arkStoreProperty(); }
:tryldglobalbyname i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x8C; i16_1; i16_2 { acc = arkLoadProperty(); }
:trystglobalbyname i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x8D; i16_1; i16_2 { arkStoreProperty(); }
:mov_wide vr1, vr2 is wide_prefix=0xFD & wide_opcode=0x8F; vr1; vr2 { local tmp:4 = vr2; vr1 = tmp; }
:ldsuperbyname i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x92; i16_1; i16_2 { acc = arkLoadProperty(); }
:stobjbyname i16_1, i16_2, vr1 is wide_prefix=0xFD & wide_opcode=0x91; i16_1; i16_2; vr1 { arkStoreProperty(); }
:ldobjbyname i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x90; i16_1; i16_2 { acc = arkLoadProperty(); }
:ldthisbyvalue i16_1 is wide_prefix=0xFD & wide_opcode=0x95; i16_1 { acc = arkLoadProperty(); }
:stthisbyvalue i16_1, vr1 is wide_prefix=0xFD & wide_opcode=0x96; i16_1; vr1 { arkStoreProperty(); }
:ldthisbyname i16_1, i16_2 is wide_prefix=0xFD & wide_opcode=0x93; i16_1; i16_2 { acc = arkLoadProperty(); }
:stthisbyname i16_1, i16_2, vr1 is wide_prefix=0xFD & wide_opcode=0x94; i16_1; i16_2; vr1 { arkStoreProperty(); }
:definefunc i16_1, i16_2, i8_1 is wide_prefix=0xFD & wide_opcode=0x74; i16_1; i16_2; i8_1 { acc = arkDefineFunc(); }
:gettemplateobject i16_1 is wide_prefix=0xFD & wide_opcode=0xC1; i16_1 { acc = arkCallRuntime(); }
:setobjectwithproto i16_1, vr1 is wide_prefix=0xFD & wide_opcode=0xC7; i16_1; vr1 { arkStoreProperty(); }
:stownbyvalue i16_1, vr1, vr2 is wide_prefix=0xFD & wide_opcode=0xC8; i16_1; vr1; vr2 { arkStoreProperty(); }
:stownbyindex i16_1, vr1, i16_2 is wide_prefix=0xFD & wide_opcode=0xCB; i16_1; vr1; i16_2 { arkStoreProperty(); }
:stownbyname i16_1, i16_2, vr1 is wide_prefix=0xFD & wide_opcode=0xCC; i16_1; i16_2; vr1 { arkStoreProperty(); }
:definemethod i16_1, i16_2, i8_1 is wide_prefix=0xFD & wide_opcode=0xBE; i16_1; i16_2; i8_1 { acc = arkDefineFunc(); }
:supercallthisrange i16_1, i8_1, vr1 is wide_prefix=0xFD & wide_opcode=0x75; i16_1; i8_1; vr1 { acc = arkCallArg(); }

# ===========================================================
# Additional 16-bit IC instructions
# ===========================================================

:jmp jmp16 is opcode=0x4E; jmp16 { goto jmp16; }
:jeqz jmp16 is opcode=0x50; jmp16 { if (acc == 0) goto jmp16; }
:jnez jmp16 is opcode=0x9B; jmp16 { if (acc != 0) goto jmp16; }
:jstricteqz jmp16 is opcode=0x9D; jmp16 { if (acc == 0) goto jmp16; }
:jnstricteqz jmp16 is opcode=0x9E; jmp16 { if (acc != 0) goto jmp16; }
:jeqnull jmp16 is opcode=0x9F; jmp16 { if (acc == 0) goto jmp16; }
:jnenull jmp16 is opcode=0xA0; jmp16 { if (acc != 0) goto jmp16; }
:jstricteqnull jmp16 is opcode=0xA1; jmp16 { if (acc == 0) goto jmp16; }
:jnstricteqnull jmp16 is opcode=0xA2; jmp16 { if (acc != 0) goto jmp16; }
:jequndefined jmp16 is opcode=0xA3; jmp16 { if (acc == 0) goto jmp16; }
:jneundefined jmp16 is opcode=0xA4; jmp16 { if (acc != 0) goto jmp16; }
:jstrictequndefined jmp16 is opcode=0xA5; jmp16 { if (acc == 0) goto jmp16; }
:jnstrictequndefined jmp16 is opcode=0xA6; jmp16 { if (acc != 0) goto jmp16; }
:jeq vr1, jmp16 is opcode=0xA7; vr1; jmp16 { if (acc == vr1) goto jmp16; }
:jne vr1, jmp16 is opcode=0xA8; vr1; jmp16 { if (acc != vr1) goto jmp16; }
:jstricteq vr1, jmp16 is opcode=0xA9; vr1; jmp16 { if (acc == vr1) goto jmp16; }
:jnstricteq vr1, jmp16 is opcode=0xAA; vr1; jmp16 { if (acc != vr1) goto jmp16; }
:getiterator i16_1 is opcode=0xAB; i16_1 { acc = arkGetIterator(); }
:closeiterator i16_1, vr1 is opcode=0xAC; i16_1; vr1 { arkCloseIterator(); }
