# Ark Bytecode SLEIGH instruction definitions
# Based on Ark ISA version 13.0.0.0 (isa.yaml)
# Register-based VM with dedicated accumulator

define endian = little;
define alignment = 1;

# Address spaces
define space ram       type=ram_space      size=4  default;
define space register  type=register_space size=4;

# Core registers
define register offset=0x00  size=4 [ sp fp acc ];
define register offset=0x08  size=8 [ acc64 ];

# Virtual registers v0-v255 (8-bit index)
define register offset=0x1000 size=4
[
     v0   v1   v2   v3   v4   v5   v6   v7
     v8   v9  v10  v11  v12  v13  v14  v15
    v16  v17  v18  v19  v20  v21  v22  v23
    v24  v25  v26  v27  v28  v29  v30  v31
    v32  v33  v34  v35  v36  v37  v38  v39
    v40  v41  v42  v43  v44  v45  v46  v47
    v48  v49  v50  v51  v52  v53  v54  v55
    v56  v57  v58  v59  v60  v61  v62  v63
    v64  v65  v66  v67  v68  v69  v70  v71
    v72  v73  v74  v75  v76  v77  v78  v79
    v80  v81  v82  v83  v84  v85  v86  v87
    v88  v89  v90  v91  v92  v93  v94  v95
    v96  v97  v98  v99 v100 v101 v102 v103
   v104 v105 v106 v107 v108 v109 v110 v111
   v112 v113 v114 v115 v116 v117 v118 v119
   v120 v121 v122 v123 v124 v125 v126 v127
   v128 v129 v130 v131 v132 v133 v134 v135
   v136 v137 v138 v139 v140 v141 v142 v143
   v144 v145 v146 v147 v148 v149 v150 v151
   v152 v153 v154 v155 v156 v157 v158 v159
   v160 v161 v162 v163 v164 v165 v166 v167
   v168 v169 v170 v171 v172 v173 v174 v175
   v176 v177 v178 v179 v180 v181 v182 v183
   v184 v185 v186 v187 v188 v189 v190 v191
   v192 v193 v194 v195 v196 v197 v198 v199
   v200 v201 v202 v203 v204 v205 v206 v207
   v208 v209 v210 v211 v212 v213 v214 v215
   v216 v217 v218 v219 v220 v221 v222 v223
   v224 v225 v226 v227 v228 v229 v230 v231
   v232 v233 v234 v235 v236 v237 v238 v239
   v240 v241 v242 v243 v244 v245 v246 v247
   v248 v249 v250 v251 v252 v253 v254 v255
];

# Custom p-code operations for VM runtime calls
define pcodeop arkThrow;
define pcodeop arkNewObject;
define pcodeop arkCallRuntime;
define pcodeop arkCallArg;
define pcodeop arkCreateArray;
define pcodeop arkCreateObject;
define pcodeop arkLoadProperty;
define pcodeop arkStoreProperty;
define pcodeop arkDefineFunc;
define pcodeop arkDynamicImport;
define pcodeop arkGetIterator;
define pcodeop arkCloseIterator;
define pcodeop arkGetPropIterator;
define pcodeop arkTypeOf;
define pcodeop arkInstanceOf;
define pcodeop arkDebugger;

# ===========================================================
# Token definitions
# Each token represents one sequential byte(s) in the instruction
# stream. Semicolons (;) separate byte positions in patterns.
# ===========================================================

# Byte 0: opcode
define token inst_byte(8)
    opcode = (0, 7)
;

# Byte 1: 8-bit register or unsigned/signed immediate
define token byte1(8)
    reg1     = (0, 7)
    uimm1    = (0, 7)
    simm1    = (0, 7) signed
;

# Byte 2: 8-bit register or unsigned/signed immediate
define token byte2(8)
    reg2     = (0, 7)
    uimm2    = (0, 7)
    simm2    = (0, 7) signed
;

# Byte 3: 8-bit register or unsigned/signed immediate
define token byte3(8)
    reg3     = (0, 7)
    uimm3    = (0, 7)
    simm3    = (0, 7) signed
;

# Byte 4: 8-bit register or unsigned/signed immediate
define token byte4(8)
    reg4     = (0, 7)
    uimm4    = (0, 7)
    simm4    = (0, 7) signed
;

# Bytes 1-2: packed 4-bit register pair (for mov)
define token byte1_4pair(8)
    reg4_lo = (0, 3)
    reg4_hi = (4, 7)
;

# Bytes 1-2: packed 4-bit immediate pair (for ldlexvar/stlexvar)
define token byte1_lex(8)
    lex_level = (0, 3)
    lex_slot  = (4, 7)
;

# Bytes 1-2: 16-bit immediate
define token bytes12(16)
    uimm16_1    = (0, 15)
    simm16_1    = (0, 15) signed
;

# Bytes 2-3: 16-bit immediate (when byte 1 is already used)
define token bytes23(16)
    uimm16_2    = (0, 15)
    simm16_2    = (0, 15) signed
;

# Bytes 3-4: 16-bit immediate (when bytes 1-2 are already used)
define token bytes34(16)
    uimm16_3    = (0, 15)
    simm16_3    = (0, 15) signed
;

# Bytes 1-4: 32-bit immediate
define token bytes1234(32)
    simm32_1 = (0, 31) signed
;

# Bytes 1-8: 64-bit immediate
define token bytes12345678(64)
    simm64_1 = (0, 63) signed
;

# Bytes 0-1: wide-prefixed instruction (0xFD xx)
define token wide_instr(16)
    wide_prefix = (0, 7)
    wide_opcode = (8, 15)
;

# ===========================================================
# Operand constructors
# ===========================================================

# Register operands (one per sequential byte position)
vr1: reg1 is reg1 { export reg1; }
vr2: reg2 is reg2 { export reg2; }
vr3: reg3 is reg3 { export reg3; }
vr4: reg4 is reg4 { export reg4; }

# 4-bit register operands (for mov, packed in single byte)
vr_lo: reg is reg4_lo  [ reg = (reg4_lo * 4) + 0x1000; ] { export *[register]:4 reg; }
vr_hi: reg is reg4_hi  [ reg = (reg4_hi * 4) + 0x1000; ] { export *[register]:4 reg; }

# Packed 4-bit immediates (lexical level and slot)
lex_lvl: lex_level is lex_level { export *[const]:1 lex_level; }
lex_slt: lex_slot  is lex_slot  { export *[const]:1 lex_slot;  }

# 8-bit immediate operands (per byte position)
i8_1: uimm1 is uimm1 { export *[const]:1 uimm1; }
i8_2: uimm2 is uimm2 { export *[const]:1 uimm2; }
i8_3: uimm3 is uimm3 { export *[const]:1 uimm3; }

# 16-bit immediate operands (per byte-pair position)
i16_1: uimm16_1 is uimm16_1 { export *[const]:2 uimm16_1; }
i16_2: uimm16_2 is uimm16_2 { export *[const]:2 uimm16_2; }
i16_3: uimm16_3 is uimm16_3 { export *[const]:2 uimm16_3; }

# 32-bit signed immediate
i32s: simm32_1 is simm32_1 { export *[const]:4 simm32_1; }

# 64-bit immediate
i64s: simm64_1 is simm64_1 { export *[const]:8 simm64_1; }

# Jump target constructors (precompute inst_start + signed offset as address)
jmp8: reloc is simm1  [ reloc = inst_start + simm1; ] { export *[ram]:4 reloc; }
jmp16: reloc is simm16_1 [ reloc = inst_start + simm16_1; ] { export *[ram]:4 reloc; }

